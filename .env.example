# 复制为 .env 后填写（勿提交 .env）
# OpenAI 官方或任意兼容 Chat Completions 的网关
OPENAI_API_KEY=sk-...
# 可选：默认 https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# 可选：默认 gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
# 部分中转（如 sub2api）非流式无完整 message，默认 true；直连官方且要用 JSON 一次性响应时可设 false
# OPENAI_STREAM=true
# 阶段一 CLI：请求超时（毫秒）
# OPENAI_TIMEOUT_MS=120000
# github_repo_lookup 的 HTTP 超时（毫秒）
# TOOL_HTTP_TIMEOUT_MS=8000
# 阶段四 SSE 端口
# PHASE4_PORT=3840
# LangSmith 可观测（可选）：https://docs.langchain.com/langsmith
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=langchain-new-study
